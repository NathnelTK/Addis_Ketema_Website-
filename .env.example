# Database connection (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/addis_ketema

# JWT secret for session tokens - change this to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-string

# Admin panel password - used to log into /admin/login
ADMIN_PASSWORD=admin123

# Manus OAuth (only needed if using Manus login, not required for local admin login)
# VITE_APP_ID=your_app_id
# OAUTH_SERVER_URL=https://api.manus.im
# VITE_OAUTH_PORTAL_URL=https://manus.im/login
# OWNER_OPEN_ID=your_open_id
